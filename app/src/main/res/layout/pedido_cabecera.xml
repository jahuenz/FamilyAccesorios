<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent" >
	<LinearLayout 
	    android:layout_width="match_parent"
	    android:layout_height="wrap_content"
	    android:orientation="vertical"
	    android:layout_margin="3dp" >
	
	    <LinearLayout
	        android:layout_width="match_parent"
	    	android:layout_height="wrap_content"
	    	android:orientation="horizontal" >
	    	
		    <TextView
		        android:id="@+id/textCodigoProducto"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="@string/cliente" />
		
		    <TextView
		        android:id="@+id/txt_nroCliente"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content" />
		    
	    </LinearLayout>
	
	    <LinearLayout
	        android:layout_width="match_parent"
	    	android:layout_height="wrap_content"
	    	android:layout_marginTop="10dp"
	    	android:orientation="vertical" >
		    
		    <TextView
		        android:id="@+id/txt_nombreCliente"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:textAppearance="?android:attr/textAppearanceMedium" />
		
		    <Button
		        android:id="@+id/btn_enviar"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="Ver datos de cliente" />
		    
		</LinearLayout>
		
	    <LinearLayout
	        android:layout_width="match_parent"
	    	android:layout_height="wrap_content"
	    	android:layout_marginTop="20dp"
	    	android:orientation="horizontal" >
	
		    <TextView
		        android:id="@+id/txtTipoPedido"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="@string/tipo_pedido" />
		
		    <Spinner
		        android:id="@+id/spinner3"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"/>
		
		</LinearLayout>    
		
		<LinearLayout
	        android:layout_width="match_parent"
	    	android:layout_height="wrap_content"
	    	android:layout_marginTop="20dp"
	    	android:orientation="horizontal" >
		    
		    <TextView
		        android:id="@+id/textCondVta"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="@string/cond_venta" />
		
		    <Spinner
		        android:id="@+id/spnCondVta"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content" />
		    
		</LinearLayout>
		
		<LinearLayout
		    android:layout_width="wrap_content"
		    android:layout_height="wrap_content"
		    android:layout_marginTop="20dp"
		    android:orientation="horizontal" >
		    
		    <TextView
		        android:id="@+id/textNroCheque"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_weight="1"
		        android:visibility="invisible"
		        android:text="@string/nro_cheque" />
	
		    <EditText
		        android:id="@+id/edtNroCheque"
		        android:layout_width="100dp"
		        android:layout_height="wrap_content"
		        android:selectAllOnFocus="true"
		        android:visibility="invisible"
		        android:maxLength="4"
		        android:inputType="number"
		        android:text="" />
		    
	    </LinearLayout>
		<LinearLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:orientation="horizontal" >

			<TextView
				android:id="@+id/textCantidadDias"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:visibility="invisible"
				android:text="@string/cant_dias" />

			<Spinner
				android:id="@+id/spnCondCheque"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:visibility="invisible"/>
		</LinearLayout>
		
		<LinearLayout
		    android:layout_width="wrap_content"
		    android:layout_height="wrap_content"
		    android:layout_marginTop="20dp"
		    android:orientation="horizontal" >
		    
		    <TextView
		        android:id="@+id/textCreditoDisponible"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_weight="1"
		        android:text="@string/cred_disponible" />
	
		    <TextView
		        android:id="@+id/textCredito"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="0" />
		    
	    </LinearLayout>
		
		<LinearLayout
		    android:layout_width="wrap_content"
		    android:layout_height="wrap_content"
		    android:layout_marginTop="20dp"
		    android:orientation="horizontal" >
		    
		    <TextView
		        android:id="@+id/textEntrega"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_weight="1"
		        android:text="Entrega: $" />
	
		    <EditText
		        android:id="@+id/edtImporteEntrega"
		        android:layout_width="114dp"
		        android:layout_height="wrap_content"
		        android:inputType="numberDecimal"
		        android:maxLength="10"
		        android:selectAllOnFocus="true"
		        android:text="0" />
		    
		    <Button
	            android:id="@+id/btn_completarEntrega"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:layout_weight="1"
	            android:text="Completar"
	            android:textSize="@dimen/boton_cabecera_" />
		    
	    </LinearLayout>
	
		<LinearLayout
		    android:layout_width="wrap_content"
		    android:layout_height="wrap_content"
		    android:layout_marginTop="20dp"
		    android:orientation="horizontal" >
		    
		    <TextView
		        android:id="@+id/textCantidad"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_weight="1"
		        android:text="Sub Total: $" />
	
		    <TextView
		        android:id="@+id/textSubTotalPedido"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
				android:layout_weight="1"
				android:layout_marginRight="10dp"
		        android:text="0" />

			<TextView
				android:id="@+id/textRecargoDe"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/recargo" />

			<TextView
				android:id="@+id/textRecargo"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="0" />
		    
	    </LinearLayout>
	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="20dp"
		android:orientation="horizontal" >

		<TextView
			android:id="@+id/textTotal"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="Total: $" />

		<TextView
			android:id="@+id/textTotalPedido"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="0" />

	</LinearLayout>


	    
	    <LinearLayout
	        android:layout_width="match_parent"
	        android:layout_height="wrap_content"
	        android:layout_marginTop="5dp"
	        android:orientation="horizontal" >
	
	        <Button
	            android:id="@+id/btn_productos"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:layout_weight="1"
	            android:text="@string/prods"
	            android:textSize="@dimen/boton_cabecera_" />
	
	        <Button
	            android:id="@+id/btn_cancelar_pedido"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:layout_weight="1"
	            android:text="@string/cancelar"
	            android:textSize="@dimen/boton_cabecera_" />
	
	        <Button
	            android:id="@+id/btn_cerrar_pedido"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:layout_weight="1"
	            android:text="@string/guardar"
	            android:textSize="@dimen/boton_cabecera_" />
	
	        <Button
	            android:id="@+id/btn_notas_cabecera"
	            android:layout_width="wrap_content"
	            android:layout_height="wrap_content"
	            android:layout_weight="1"
	            android:text="@string/notas"
	            android:textSize="@dimen/boton_cabecera_" />
	
	    </LinearLayout>
	
	</LinearLayout>
</ScrollView>