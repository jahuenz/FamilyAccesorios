<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/txt_nombre_cobro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="NOMBRE" />

        <TextView
            android:id="@+id/txt_saldo_cta_cte"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="SALDO CUENTA CORRIENTE" />

        <TextView
            android:id="@+id/txt_credito_disponible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="CREDITO DISPONIBLE" />


        <TextView
            android:id="@+id/txt_fecha_cobro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="FECHA" />

        <TextView
            android:id="@+id/txt_forma_pago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="FORMA DE PAGO" />
        <TextView
            android:id="@+id/txt_total_cobro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:text="TOTAL" />


    </LinearLayout>


</LinearLayout>